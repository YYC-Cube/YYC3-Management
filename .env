# ============================================================
# YYC³ 企业智能管理系统 — 环境变量配置清单
# 复制此文件为 .env.local 并填入实际值
# 版本: v3.0.0 | 更新: 2026-07-17
# ============================================================

# ====================================
# 应用基础配置
# ====================================
NEXT_PUBLIC_APP_URL=http://localhost:3223
NEXT_PUBLIC_APP_NAME=YYC³企业管理系统
NEXT_PUBLIC_API_BASE_URL=https://api.0379.love
NEXT_PUBLIC_API_URL=https://api.0379.love
NEXT_PUBLIC_LOCAL_MODEL_ENDPOINT=http://localhost:11434
NEXT_PUBLIC_VECTOR_DB_URL=your_vector_db_url_here
NEXT_PUBLIC_BAIDU_ANALYTICS_ID=your_baidu_analytics_id_here
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here
NEXT_PUBLIC_ENABLE_MOCK=false

# ====================================
# 环境标识 / 运行时
# ====================================
NODE_ENV=development
LOG_LEVEL=info
PORT=3223
HOSTNAME=0.0.0.0

# ====================================
# AI 模型配置 — 云端服务
# ====================================

# OpenAI（通用接口）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# 百度文心一言
BAIDU_API_KEY=your_baidu_api_key_here
BAIDU_SECRET_KEY=your_baidu_secret_key_here

# 阿里通义千问
ALIBABA_API_KEY=your_alibaba_api_key_here

# 智谱 GLM（ChatGLM）
ZHIPU_API_KEY=your_zhipu_api_key_here

# 讯飞星火
XUNFEI_APP_ID=your_xunfei_app_id_here
XUNFEI_API_KEY=your_xunfei_api_key_here
XUNFEI_API_SECRET=your_xunfei_api_secret_here

# 腾讯混元
TENCENT_SECRET_ID=your_tencent_secret_id_here
TENCENT_SECRET_KEY=your_tencent_secret_key_here

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1

# Moonshot / Kimi
MOONSHOT_API_KEY=your_moonshot_api_key_here
MOONSHOT_API_BASE_URL=https://api.moonshot.cn/v1

# ====================================
# AI 模型配置 — 本地部署
# ====================================

# Ollama 本地模型
OLLAMA_BASE_URL=http://localhost:11434

# LM Studio 本地模型
LM_STUDIO_BASE_URL=http://localhost:1234

# ====================================
# 数据库配置
# ====================================

# PostgreSQL 连接串（优先级最高）
DATABASE_URL=postgresql://yanyu@localhost:5433/yyc3_33

# PostgreSQL 分项配置（供 client.ts 回退使用）
DB_HOST=localhost
DB_PORT=5433
DB_USER=yanyu
DB_PASSWORD=
DB_NAME=yyc3_33
DB_USERNAME=yanyu
DB_DATABASE=yyc3_33

# Redis 缓存
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ====================================
# 安全配置
# ====================================

# JWT 密钥（生产环境请使用强随机字符串，≥32字符）
JWT_SECRET=your_jwt_secret_key_here_min_32_characters
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_min_32_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Session 密钥（≥32字符）
SESSION_SECRET=your_session_secret_here_min_32_characters

# ====================================
# 第三方服务集成
# ====================================

# 邮件服务（SMTP）
EMAIL_HOST=smtp.your_email_provider.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email_username_here
EMAIL_PASSWORD=your_email_password_here
EMAIL_FROM=noreply@your_domain.com

# 对象存储（OSS/S3）
STORAGE_REGION=your_storage_region_here
STORAGE_BUCKET=your_bucket_name_here
STORAGE_ACCESS_KEY_ID=your_access_key_id_here
STORAGE_ACCESS_KEY_SECRET=your_access_key_secret_here

# 内部/外部 API 密钥
INTERNAL_API_KEY=your_internal_api_key_here
EXTERNAL_API_KEY=your_external_api_key_here

# 腾讯云（通用）
TENCENT_API_KEY=your_tencent_api_key_here

# 高德地图（AMap）
AMAP_KEY=your_amap_key_here
AMAP_SECURITY_CODE=your_amap_security_code_here

# 七鱼客服（Qiyu）
QIYU_APP_KEY=your_qiyu_app_key_here
QIYU_APP_SECRET=your_qiyu_app_secret_here

# 百度统计（Baidu Analytics）
BAIDU_ANALYTICS_ID=your_baidu_analytics_id_here
BAIDU_ANALYTICS_API_KEY=your_baidu_analytics_api_key_here

# Sentry 错误监控
SENTRY_DSN=your_sentry_dsn_here
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here

# ====================================
# 微信生态（可选）
# ====================================

# 微信公众号
WECHAT_APP_ID=your_wechat_app_id_here
WECHAT_APP_SECRET=your_wechat_app_secret_here
WECHAT_API_BASE_URL=https://api.weixin.qq.com
NEXT_PUBLIC_WECHAT_APPID=your_wechat_app_id_here

# ====================================
# 功能开关
# ====================================
ENABLE_ANALYTICS=true
ENABLE_AI_FEATURES=true
ENABLE_REALTIME=true
ENCRYPTION_KEY=your_encryption_key_here
