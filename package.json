    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "recharts": "^3.9.2",
    "redis": "^6.1.0",
    "sonner": "^2.0.7",
    "sucrase": "^3.35.1",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
