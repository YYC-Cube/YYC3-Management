{
  "name": "yyc3-mana",
  "version": "3.0.0",
  "description": "YYC³ - 企业智能管理系统，集成AI助手、客户管理、任务管理等功能",
  "author": "YYC³ <admin@0379.email>",
  "license": "MIT",
  "private": true,
  "homepage": "https://github.com/yyc3/yyc3-mana#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/yyc3/yyc3-mana.git"
  },
  "bugs": {
    "url": "https://github.com/yyc3/yyc3-mana/issues"
  },
  "keywords": [
    "yyc3",
    "enterprise",
    "management",
    "ai-assistant",
    "crm",
    "typescript",
    "nextjs"
  ],
  "scripts": {
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "dev": "next dev -p 3223",
    "lint": "next lint",
    "start": "next start -p 3223",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:lib": "vitest run --dir lib",
    "test:components": "vitest run --dir components",
    "test:performance": "vitest run lib/performance/",
    "test:fast": "vitest run --no-coverage --reporter=verbose",
    "test:debug": "vitest run --no-coverage --reporter=verbose --logHeapUsage",
    "security:scan": "./scripts/security-scan.sh",
    "security:audit": "bun audit",
    "security:fix": "bun audit fix",
    "perf:apply-config": "cp next.config.optimized.mjs next.config.mjs",
    "perf:backup-config": "cp next.config.mjs next.config.mjs.backup",
    "perf:monitor": "node scripts/performance-monitor.js",
    "db:migrate": "bun run scripts/run-migrations.ts",
    "db:seed": "bun run scripts/seed.ts"
  },
  "dependencies": {
