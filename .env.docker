# ============================================================
# YYC³ 企业智能管理系统 — Docker 环境变量
# 版本: v3.0.0 | 更新: 2026-07-17
# ============================================================

# ====================================
# 应用配置
# ====================================
NODE_ENV=production
PORT=3223
HOSTNAME=0.0.0.0
NEXT_PUBLIC_APP_URL=https://management.yyc3.vip
NEXT_PUBLIC_APP_NAME=YYC³企业管理系统
NEXT_PUBLIC_API_URL=https://api.yyc3.com
NEXT_PUBLIC_API_BASE_URL=https://api.yyc3.com
LOG_LEVEL=info

# ====================================
# 数据库配置
# ====================================
DATABASE_URL=postgresql://yyc3user:yyc3password@postgres:5432/yyc3db
DB_HOST=postgres
DB_PORT=5432
DB_USER=yyc3user
DB_PASSWORD=yyc3password
DB_NAME=yyc3db

# ====================================
# Redis 缓存
# ====================================
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# ====================================
# 安全配置
# ====================================
JWT_SECRET=your-jwt-secret-here-32-chars-minimum
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=your-session-secret-here-32-chars-minimum
ENCRYPTION_KEY=your-encryption-key-here

# ====================================
# AI 模型配置
# ====================================
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
ZHIPU_API_KEY=your-zhipu-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here
MOONSHOT_API_KEY=your-moonshot-api-key-here
OLLAMA_BASE_URL=http://ollama:11434
NEXT_PUBLIC_LOCAL_MODEL_ENDPOINT=http://ollama:11434

# ====================================
# 第三方服务
# ====================================
SENTRY_DSN=your-sentry-dsn-here
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here

# ====================================
# 功能开关
# ====================================
ENABLE_ANALYTICS=true
ENABLE_AI_FEATURES=true
ENABLE_REALTIME=true
NEXT_PUBLIC_ENABLE_MOCK=false
